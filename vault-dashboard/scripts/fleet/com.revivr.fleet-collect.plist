<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.revivr.fleet-collect</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__HOME__/.revivr/fleet/fleet-collect.sh</string>
  </array>
  <key>StartInterval</key>
  <integer>180</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HOME__/.revivr/fleet/collect.out.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.revivr/fleet/collect.err.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
